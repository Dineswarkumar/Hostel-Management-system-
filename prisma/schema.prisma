datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  phone         String?
  name          String
  role          String   // "STUDENT" | "STAFF" | "ADMIN" | "SUPER_ADMIN"
  hostelId      String?  @default("h_main")
  roomId        String?
  roomNumber    String?
  blockName     String?
  avatarUrl     String?
  parentPhone   String?
  createdAt     DateTime @default(now())
  password      String   // Plain text password for local demo accounts

  complaints    Complaint[]
  busVotes      BusVote[]
  announcements Announcement[]
}

model Announcement {
  id           String   @id @default(uuid())
  title        String
  body         String
  postedById   String
  postedByName String
  targetRole   String?  // Null means all roles, otherwise e.g. "STUDENT" or "STAFF"
  pinned       Boolean  @default(false)
  priority     String   // "LOW" | "NORMAL" | "HIGH" | "URGENT"
  createdAt     DateTime @default(now())

  postedBy     User     @relation(fields: [postedById], references: [id], onDelete: Cascade)
}

model Complaint {
  id             String   @id // e.g. "C-2489"
  userId         String
  userName       String
  userRoom       String?
  category       String   // "ELECTRICAL" | "PLUMBING" | "WIFI" | "FURNITURE" | "CLEANING" | "OTHER"
  title          String
  description    String
  photos         String   // JSON string array of photos
  priority       String   // "LOW" | "NORMAL" | "HIGH" | "URGENT"
  status         String   // "PENDING" | "ASSIGNED" | "IN_PROGRESS" | "RESOLVED" | "CLOSED"
  assignedToId   String?
  assignedToName String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  resolvedAt     DateTime?
  rating         Int?     // 1-5, post-resolution

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bus {
  id            String   @id @default(uuid())
  name          String
  time          String   // "07:30"
  description   String
  status        String   // "SCHEDULED" | "RUNNING" | "LEFT" | "CANCELLED" | "DELAYED"
  upvotes       Int      @default(0)
  downvotes     Int      @default(0)
  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  votes         BusVote[]
}

model BusVote {
  id        String   @id @default(uuid())
  busId     String
  userId    String
  type      String   // "UP" | "DOWN"
  createdAt DateTime @default(now())

  bus       Bus      @relation(fields: [busId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([busId, userId])
}

model FeeInvoice {
  id            String   @id // e.g. "inv_2026_07"
  userId        String
  roomType      String   // "SINGLE_SEATER" etc.
  month         String   // "2026-07"
  components    String   // JSON array of components: [{ name, amount }]
  total         Int
  dueDate       String   // "2026-07-15"
  status        String   // "PENDING" | "PAID" | "OVERDUE" | "FAILED"
  paidAt        DateTime?
  transactionId String?
}
